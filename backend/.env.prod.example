# backend/.env de PRODUCCIÓN
# cp backend/.env.prod.example backend/.env && nano backend/.env
# limpiar comentarios inline: sed -i -E 's/[[:space:]]+#.*$//' backend/.env
ENVIRONMENT=production

# Supabase Cloud (Settings → API) — la app usa REST con estas:
SUPABASE_URL=https://TUPROYECTO.supabase.co
SUPABASE_PUBLIC_URL=https://TUPROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Solo para CORRER MIGRACIONES (Session pooler, IPv4). La app NO lo usa en runtime.
DATABASE_URL=postgresql://postgres.TUPROYECTO:TU_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# Auth del panel y del agente de campo (generá JWT_SECRET con: openssl rand -hex 32)
JWT_SECRET=CAMBIAR_openssl_rand_hex_32
ADMIN_EMAIL=admin@buscadonde.com
ADMIN_PASSWORD=CAMBIAR
AGENTE_EMAIL=agente@buscadonde.com
AGENTE_PASSWORD=CAMBIAR

FRONTEND_URL=https://buscadonde.com
STORAGE_BUCKET=publicaciones
COMERCIOS_BUCKET=comercios

# WhatsApp (WAHA) — cuando lo despliegues. En producción, sin WEBHOOK_SECRET el
# endpoint /ingest/webhook RECHAZA todo (fail-closed). Generá: openssl rand -hex 24
WEBHOOK_SECRET=
WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=

# Transcripción del '¿qué vende?' (Whisper). Vacío = el agente escribe a mano.
OPENAI_API_KEY=
