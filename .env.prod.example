# .env de PRODUCCIÓN (raíz) — sustitución del docker-compose.prod.yml
# cp .env.prod.example .env && nano .env   ·   luego: sed -i -E 's/[[:space:]]+#.*$//' .env
DOMAIN=encontralo.store
# DOMAIN_ALT (opcional): segundo dominio servido en simultáneo durante la migración.
# Dejalo vacío/borralo cuando termine el cutover. Ver docs/migracion-encontralo-store.md
DOMAIN_ALT=buscadonde.com

# Claves PÚBLICAS de Supabase Cloud (Settings → API). Se hornean en el frontend.
NEXT_PUBLIC_SUPABASE_URL=https://TUPROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_PUBLIC_KEY
